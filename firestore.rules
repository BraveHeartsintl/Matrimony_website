rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == "admin"
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function adminBootstrapOpen() {
      return !exists(/databases/$(database)/documents/platformStats/adminBootstrap);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /verificationRequests/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    match /interests/{interestId} {
      allow read: if isAdmin()
        || (isSignedIn()
          && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid));
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.toUserId == request.auth.uid
          || resource.data.fromUserId == request.auth.uid);
    }

    match /conversations/{conversationId} {
      // Demo matrimony app: any signed-in member can use messaging.
      allow read, create, update: if isSignedIn();

      match /messages/{messageId} {
        allow read, create: if isSignedIn();
      }
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isOwner(userId);
      allow read, delete: if isAdmin();
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin();
    }

    match /platformStats/adminBootstrap {
      allow read: if true;
      allow create: if isSignedIn() && adminBootstrapOpen();
    }

    match /platformStats/{docId} {
      allow read: if true;
      allow write: if isAdmin() && docId != "adminBootstrap";
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update: if isAdmin();
    }
  }
}
